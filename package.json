    "@prisma/client": "^7.8.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.52.0",
    "bullmq": "^5.76.8",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.0",
