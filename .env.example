# ─── App ───
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database (Postgres) ───
# Dev local:  postgresql://aproxima:aproxima_dev@localhost:5434/aproxima
# Neon prod:  DATABASE_URL = pooled endpoint (pgbouncer)
#             DIRECT_URL   = direct endpoint  (sem pgbouncer, obrigatório para migrations)
DATABASE_URL=postgresql://aproxima:aproxima_dev@localhost:5434/aproxima
DIRECT_URL=postgresql://aproxima:aproxima_dev@localhost:5434/aproxima

# ─── Auth.js v5 ───
# OBRIGATÓRIO gerar antes de subir o app:
#   openssl rand -base64 32
# Valores placeholder (change_me, xxxx, example…) são rejeitados pelo schema.
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── Redis (BullMQ + cache + rate-limit) ───
# Local Docker: redis://localhost:6381
# Upstash (prod): rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6381

# ─── WhatsApp Cloud API (Meta) ───
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_GRAPH_VERSION=v21.0
META_ACCESS_TOKEN=

# ─── LLM (Anthropic Claude Haiku) ───
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=2048

# ─── Storage (Cloudflare R2) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ─── Email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM=AproximaAI <noreply@aproxima.ai>

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Observability ───
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=

# ─── Evolution API (WhatsApp QR-code — roda na VPS) ───
# Dev local: http://localhost:8181  (docker-compose.yml)
# Prod VPS:  https://evolution.seudominio.com
EVOLUTION_API_URL=http://localhost:8181
EVOLUTION_API_KEY=evolution_dev_key
# Segredo exclusivo para validar webhooks recebidos. Em prod: valor diferente de EVOLUTION_API_KEY.
# Se não definido, usa EVOLUTION_API_KEY como fallback (retrocompatibilidade).
EVOLUTION_WEBHOOK_SECRET=

# ─── Workers / i18n ───
WORKER_CONCURRENCY=10
DEFAULT_LOCALE=pt-BR
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_CURRENCY=BRL
